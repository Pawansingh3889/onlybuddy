# ── Firebase ─────────────────────────────────────────────────
# Firebase Console → Project Settings → General → Your Apps
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=

# ── Stripe ────────────────────────────────────────────────────
# Stripe Dashboard → Developers → API Keys
REACT_APP_STRIPE_PUBLIC_KEY=pk_live_...
# Also set this in Vercel environment variables (NOT here — secret key must never be in frontend):
# STRIPE_SECRET_KEY=sk_live_...

# ── EmailJS ───────────────────────────────────────────────────
# emailjs.com → Account → Services / Templates
REACT_APP_EMAILJS_SERVICE_ID=service_...
REACT_APP_EMAILJS_TEMPLATE_ID=template_...      # Customer booking confirmation template
REACT_APP_EMAILJS_ADMIN_TEMPLATE_ID=template_... # Admin new-application notification template
REACT_APP_EMAILJS_PUBLIC_KEY=...

# ── Admin contact ─────────────────────────────────────────────
REACT_APP_ADMIN_EMAIL=admin@onlybuddy.co.uk
REACT_APP_ADMIN_WHATSAPP=447700000000           # Format: 44 + number, no spaces or +

# ── App URL ───────────────────────────────────────────────────
# Used in emails and WhatsApp notifications
REACT_APP_BASE_URL=https://onlybuddy.vercel.app

# ── Google Maps (optional) ────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials
REACT_APP_GOOGLE_MAPS_KEY=
